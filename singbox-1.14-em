{
  "log": {
    "disabled": true,
    "level": "error",
    "timestamp": true
  },
  "ntp": {
    "enabled": true,
    "server": "ntp.aliyun.com",
    "server_port": 123,
    "interval": "30m"
  },
  "dns": {
    "servers": [
      {
        "tag": "google",
        "type": "h3",
        "server": "8.8.8.8",
        "detour": "🛜 Proxy"
      },
      {
        "tag": "ali",
        "type": "udp",
        "server": "223.5.5.5"
      },
      {
        "tag": "ali-doh",
        "type": "https",
        "server": "223.5.5.5",
        "server_port": 443
      },
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15"
      }
    ],
    "rules": [
      {
        "domain_suffix": [
          "app-measurement.com",
          "hm.baidu.com",
          "firebaselogging.googleapis.com",
          "firebaselogging-pa.googleapis.com",
          "beacons.gvt2.com",
          "beacons2.gvt2.com",
          "beacons3.gvt2.com",
          "tracking.miui.com"
        ],
        "action": "reject"
      },
      {
        "clash_mode": "Direct",
        "server": "ali"
      },
      {
        "clash_mode": "Global",
        "server": "fakeip"
      },
      {
        "query_type": "HTTPS",
        "action": "reject"
      },
      {
        "query_type": "AAAA",
        "action": "reject"
      },
      {
        "rule_set": "cn_domain",
        "server": "ali"
      },
      {
        "query_type": "A",
        "server": "fakeip",
        "rewrite_ttl": 1
      }
    ],
    "final": "google",
    "strategy": "prefer_ipv4",
    "cache_capacity": 500,
    "optimistic": true
  },
  "route": {
    "default_domain_resolver": {
      "server": "ali",
      "strategy": "ipv4_only"
    },
    "rules": [
      {
        "action": "sniff",
        "sniffer": [
          "http",
          "tls",
          "quic",
          "dns"
        ],
        "timeout": "150ms"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "port": 53 },
          { "protocol": "dns" }
        ],
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "outbound": "🎯 Direct"
      },
      {
        "clash_mode": "Global",
        "outbound": "🌐 Global"
      },
      {
        "clash_mode": "Direct",
        "outbound": "🎯 Direct"
      },
      {
        "rule_set": "cn_domain",
        "outbound": "🇨🇳 CN"
      },
      {
        "rule_set": "cn_ip",
        "outbound": "🇨🇳 CN"
      },
      {
        "rule_set": "bilibili_domain",
        "outbound": "📺 Bilibili"
      },
      {
        "rule_set": "netflix_domain",
        "outbound": "🎬 Netflix"
      },
      {
        "rule_set": "twitter_domain",
        "outbound": "✖️ Twitter"
      },
      {
        "rule_set": "youtube_domain",
        "outbound": "▶️ YouTube"
      },
      {
        "rule_set": "openai_domain",
        "outbound": "🤖 OpenAI"
      },
      {
        "rule_set": "telegram_domain",
        "outbound": "✈️ Telegram"
      },
      {
        "rule_set": "google_domain",
        "outbound": "🧲 Google"
      },
      {
        "rule_set": "apple_domain",
        "outbound": "🍎 Apple"
      },
      {
        "rule_set": "crypto_domain",
        "outbound": "💰 Crypto"
      },
      {
        "rule_set": "proxy_domain",
        "outbound": "🛜 Proxy"
      },
      {
        "action": "resolve",
        "strategy": "prefer_ipv4"
      },
      {
        "rule_set": "netflix_ip",
        "outbound": "🎬 Netflix"
      },
      {
        "rule_set": "telegram_ip",
        "outbound": "✈️ Telegram"
      },
      {
        "rule_set": "google_ip",
        "outbound": "🧲 Google"
      },
      {
        "rule_set": "apple_ip",
        "outbound": "🍎 Apple"
      }
    ],
    "rule_set": [
      {
        "tag": "apple_ip",
        "type": "remote",
        "format": "binary",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo-lite/geoip/apple.srs",
        "download_detour": "🎯 Direct",
        "update_interval": "7d"
